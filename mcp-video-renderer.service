[Unit]
Description=MCP Video Renderer (Hyperframes)
After=network.target

[Service]
Type=simple
User=hermes
WorkingDirectory=/var/lib/hermes/mcp-video-renderer
Environment=NODE_ENV=production
EnvironmentFile=/var/lib/hermes/mcp-video-renderer/.env
ExecStart=/usr/bin/node /var/lib/hermes/mcp-video-renderer/src/index.js
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
