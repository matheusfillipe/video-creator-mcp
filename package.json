{
  "name": "video-creator-mcp",
  "version": "0.1.2",
  "description": "Agent-driven video-creation MCP server: scavenge sources (YouTube, web), composite, and render video via Hyperframes.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "video-creator-mcp": "dist/index.js"
  },
  "files": ["dist", "gsap", "python", "skills", ".env.example", "README.md", "LICENSE"],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "video",
    "ai-agent",
    "hyperframes",
    "ffmpeg",
    "youtube-dl",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/matheusfillipe/video-creator-mcp.git"
  },
  "license": "MIT",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "clean": "rm -rf dist coverage",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src tests scripts",
    "format": "biome format --write src tests scripts",
    "check": "biome check --write src tests scripts",
    "docs:tools": "tsx scripts/gen-tools-doc.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "husky || true",
    "prepublishOnly": "npm run build && npm run docs:tools"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "lint-staged": {
    "*.{ts,json,jsonc}": "biome check --write --no-errors-on-unmatched"
  }
}
