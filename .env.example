# Transport: "http" (remote, default) or "stdio" (local subprocess)
TRANSPORT=http
# HTTP server port
PORT=3100
# Optional shared secret for the HTTP transport (sent by clients as the x-api-key header).
# Leave unset to disable auth (e.g. behind a trusted gateway like Kong).
# MCP_API_KEY=change-me

# Storage: "local" or "s3"
STORAGE_TYPE=local
STORAGE_PATH=./output
# Base URL for accessing rendered files (no trailing slash)
# PUBLIC_URL=https://video.t3ks.com/output

# S3/MinIO settings (when STORAGE_TYPE=s3)
# S3_ENDPOINT=https://s3.t3ks.com
# S3_BUCKET=renders
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Temp working dir for render jobs
WORKDIR=/tmp/video-creator-jobs
# Downloaded media cache directory
# MEDIA_CACHE_DIR=~/.cache/video-creator-mcp/media
# Netscape cookies.txt path for authenticated yt-dlp downloads
# YTDLP_COOKIES=
# Enable video_render_manim (arbitrary manim scene code = Python execution on this
# host). Leave off unless every client with an API key is trusted.
# MANIM_SCENES=true
