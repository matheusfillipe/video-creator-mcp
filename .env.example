# Storage: "local" or "s3"
STORAGE_TYPE=local
# Local: where to write rendered videos
STORAGE_PATH=./output
# Base URL for accessing rendered files (no trailing slash)
PUBLIC_URL=https://render.t3ks.com/output

# S3/Minio settings (when STORAGE_TYPE=s3)
# S3_ENDPOINT=https://s3.t3ks.com
# S3_BUCKET=renders
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Server port
PORT=3100

# Temp working dir for render jobs
WORKDIR=/tmp/mcp-render-jobs
